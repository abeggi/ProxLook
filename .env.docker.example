# ProxLook Docker Environment Configuration
# Copy this file to .env and modify as needed

# Application port
APP_PORT=8090

# Database configuration
# Use SQLite with persistent volume in Docker
DATABASE_URL=sqlite:////app/data/proxlook.db

# Logging configuration
LOG_LEVEL=INFO
LOG_PATH=/app/app.log
LOG_MAX_BYTES=5242880    # 5MB
LOG_BACKUP_COUNT=5

# Optional: Custom scan frequency (cron expression)
# SCAN_CRON=*/5 * * * *   # Every 5 minutes
# SCAN_CRON=0 * * * *     # Every hour
# SCAN_CRON=0 0 * * *     # Daily at midnight

# Note: PVE host configurations are stored in the database
# and can be managed through the web interface